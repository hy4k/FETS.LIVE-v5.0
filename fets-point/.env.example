# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# GBP OAuth (from Google Cloud Console)
VITE_GBP_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com

# GBP Location IDs (from Google Business Profile API)
# Format: accounts/{accountId}/locations/{locationId}
VITE_GBP_LOCATION_COCHIN=accounts/YOUR_ACCOUNT_ID/locations/YOUR_COCHIN_LOCATION_ID
VITE_GBP_LOCATION_CALICUT=accounts/YOUR_ACCOUNT_ID/locations/YOUR_CALICUT_LOCATION_ID

# App URL
VITE_APP_URL=https://fets.live

# CMA Availability Scraper (scripts/scrape-prometric.js)
# SUPABASE_SERVICE_ROLE_KEY is required by the scraper so it can bypass RLS.
# Get it from: Supabase Dashboard → Project Settings → API → service_role key
# ⚠️  Never expose this key in the frontend or commit it to git.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
