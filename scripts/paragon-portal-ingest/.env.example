# Copy to .env (gitignored) and fill in. Never commit real values.

# Paragon test centre portal (login page URL — adjust if Paragon changes paths)
PARAGON_PORTAL_URL=https://testcentreportal.paragontesting.ca/TestCentrePortal/Login

# Cochin centre credentials (portal account)
PARAGON_COCHIN_EMAIL=
PARAGON_COCHIN_PASSWORD=

# Calicut centre credentials (portal account)
PARAGON_CALICUT_EMAIL=
PARAGON_CALICUT_PASSWORD=

# Supabase Edge Function (ingest mode)
SUPABASE_FUNCTION_URL=https://qqewusetilxxfvfkmsed.supabase.co/functions/v1/paragon-schedule-sync
SUPABASE_ANON_KEY=
PARAGON_SYNC_SECRET=

# Month window (must match CELPIP calendar / Edge Function filter)
PARAGON_START_MONTH=2026-04
PARAGON_END_MONTH=2026-06

# playwright: "true" | "false" (default true)
PLAYWRIGHT_HEADLESS=true
